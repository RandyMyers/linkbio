PORT=4000
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/linkbio

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=14d

# CORS — primary client origin (Netlify / production SPA)
CLIENT_ORIGIN=http://localhost:3000
# Extra browser origins (comma-separated). localhost:3000 and :3001 are always allowed.
ADDITIONAL_CORS_ORIGINS=https://courageous-cocada-20fd5a.netlify.app
APP_PUBLIC_URL=http://localhost:3000
# Public URL of this API (for NOWPayments IPN callbacks)
API_PUBLIC_URL=http://localhost:4000

# Analytics visitor hashing (required for POST /api/events)
EVENT_IP_SALT=change-me-daily-rotating-salt

# Gateway credentials are stored encrypted in MongoDB (SECRETS_MASTER_KEY).
# Optional env fallbacks are not used for Flutterwave/Squad — configure in admin → Gateways.

# NOWPayments — crypto subscription & product checkout
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Optional override (defaults to API_PUBLIC_URL/api/webhooks/nowpayments)
# NOWPAYMENTS_IPN_CALLBACK_URL=https://your-api.example.com/api/webhooks/nowpayments

# Bank transfer — shown on GET /api/billing (plain text / markdown)
PAYMENT_INSTRUCTIONS_BANK=Wire to: Your Bank, Account name, IBAN, Reference: your@email
PAYMENT_INSTRUCTIONS_CRYPTO=Pay with BTC, ETH, USDT via NOWPayments checkout link.

# Cloudinary uploads (already in your .env)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Custom domains
CUSTOM_DOMAIN_CNAME_TARGET=proxy.linkbio.app
# DOMAIN_VERIFY_DEV_AUTO=1

# Optional SMTP — subscription reminder emails (otherwise logged in development)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# EMAIL_FROM=noreply@linkbio.app

# Admin — comma-separated emails allowed to use /api/admin (must match an existing User)
ADMIN_EMAILS=admin@linkbio.local

# Dev seed — creates/updates admin user on server start (do not use weak passwords in production)
ADMIN_SEED_EMAIL=admin@linkbio.local
ADMIN_SEED_PASSWORD=Admin123!

# Encrypt gateway credentials in MongoDB (admin → Settings → Gateways)
# Falls back to NOWPAYMENTS_* env vars when DB is empty
SECRETS_MASTER_KEY=

# Mailchimp marketing (optional — prefer admin → Marketing → Settings)
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=us21
# MAILCHIMP_DEFAULT_LIST_ID=
# MAILCHIMP_WEBHOOK_SECRET=
# MAILCHIMP_CONTACT_LIMIT=500

OG_CACHE_TTL_SEC=3600

# Logo.dev — social platform icons (publishable pk_ + secret sk_)
LOGO_DEV_TOKEN=
LOGO_DEV_SECRET=
